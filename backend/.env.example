# Copy to .env for local (non-Docker) runs:  cp .env.example .env
#
# Database connection string. Defaults to a local SQLite file if unset.
# For the docker-compose Postgres service, DATABASE_URL is injected by
# docker-compose.yml and you do NOT need this file.
#
# Local SQLite (simplest):
DATABASE_URL=sqlite:///./lolbin.db
#
# Local Postgres example:
# DATABASE_URL=postgresql+psycopg2://lolbin:lolbin_pass@localhost:5432/lolbin_db
